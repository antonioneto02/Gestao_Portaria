            const tiposSet = new Set(); const statusSet = new Set(); const usersSet = new Set();
            let totalRecords = 0;
            filteredData.forEach(function(row) {
              try {
                if (row.length > 1 && row[1] && String(row[1]).trim()) tiposSet.add(String(row[1]).trim());
                if (row.length > 8 && row[8] && String(row[8]).trim()) statusSet.add(String(row[8]).trim());
