<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | CINI</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <script>
        const interceptors = {
            appendChild: Element.prototype.appendChild,
            insertBefore: Element.prototype.insertBefore,
            insertAdjacentElement: Element.prototype.insertAdjacentElement,
            insertAdjacentHTML: Element.prototype.insertAdjacentHTML,
            prepend: Element.prototype.prepend,
            append: Element.prototype.append
        };

        const isBackToTop = (node) => {
            if (!node) return false;
            if (node.classList?.contains('back-to-top')) return true;
            if (node.classList?.contains('scroll-top')) return true;
            if (typeof node === 'string' && node.includes('back-to-top')) return true;
            return false;
        };

        Element.prototype.appendChild = function(node) {
            return isBackToTop(node) ? node : interceptors.appendChild.call(this, node);
        };
        Element.prototype.insertBefore = function(node, ref) {
            return isBackToTop(node) ? node : interceptors.insertBefore.call(this, node, ref);
        };
        Element.prototype.insertAdjacentElement = function(pos, elem) {
            return isBackToTop(elem) ? elem : interceptors.insertAdjacentElement.call(this, pos, elem);
        };
        Element.prototype.insertAdjacentHTML = function(pos, html) {
            return isBackToTop(html) ? undefined : interceptors.insertAdjacentHTML.call(this, pos, html);
        };
        Element.prototype.prepend = function(...nodes) {
            nodes = nodes.filter(n => !isBackToTop(n));
            return nodes.length ? interceptors.prepend.apply(this, nodes) : undefined;
        };
        Element.prototype.append = function(...nodes) {
            nodes = nodes.filter(n => !isBackToTop(n));
            return nodes.length ? interceptors.append.apply(this, nodes) : undefined;
        };

        window.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.back-to-top, .scroll-top').forEach(el => el.remove());
            setInterval(() => {
                document.querySelectorAll('.back-to-top, .scroll-top').forEach(el => el.remove());
            }, 100);
        });
    </script>
    
    <link rel="stylesheet" href="/assets/styles.css">
    <style>
        body { background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%); display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .login-container { width: 100%; max-width: 420px; padding: 20px; }
        .login-card { background: white; border-radius: 12px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); overflow: hidden; }
        .login-header { background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%); color: white; padding: 40px 20px; text-align: center; }
        .login-logo { width: 80px; height: 80px; background: rgba(255,255,255,0.1); border-radius: 12px; display:flex; align-items:center; justify-content:center; margin:0 auto 16px; object-fit:contain; padding:10px; }
        .back-to-top, .back-to-top.show, .scroll-top, .scroll-top.show { display: none !important; visibility: hidden !important; opacity: 0 !important; width: 0 !important; height: 0 !important; margin: 0 !important; padding: 0 !important; border: none !important; pointer-events: none !important; }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <img src="/assets/image/Cini.png" alt="CINI" class="login-logo">
                <h1>CINI</h1>
                <p>Sistema Integrado de Gestão da Portaria</p>
            </div>

            <div class="login-body">
                <% if (error) { %>
                <div class="alert-box alert-danger">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span><%= error %></span>
                </div>
                <% } %>

                <form method="POST" action="/login">
                    <div class="form-group">
                        <label>Email ou Usuário</label>
                        <input type="text" name="email" placeholder="admin@sistema.com" required autofocus>
                    </div>

                    <div class="form-group">
                        <label>Senha</label>
                        <div class="input-group">
                            <input type="password" id="password" name="password" placeholder="••••••••" required>
                            <button type="button" class="toggle-password" onclick="togglePassword()">
                                <i class="bi bi-eye" id="eyeIcon"></i>
                            </button>
                        </div>
                    </div>

                    <div class="form-check">
                        <input type="checkbox" id="remember" name="remember">
                        <label for="remember">Lembrar-me neste dispositivo</label>
                    </div>

                    <button type="submit" class="btn-login">
                        <i class="bi bi-box-arrow-in-right" style="margin-right: 8px;"></i>
                        Entrar
                    </button>
                </form>
            </div>
            <div class="login-footer">
                <i class="bi bi-shield-check"></i> Gestão Portaria CINI v1.0 • © 2026 CINI.DEV
            </div>
        </div>
    </div>

    <script>
        function togglePassword() {
            const input = document.getElementById('password');
            const icon = document.getElementById('eyeIcon');
            if (input.type === 'password') { input.type = 'text'; icon.classList.remove('bi-eye'); icon.classList.add('bi-eye-slash'); } else { input.type = 'password'; icon.classList.remove('bi-eye-slash'); icon.classList.add('bi-eye'); }
        }
        
        function removeAllBackToTop() {
            document.querySelectorAll('.back-to-top').forEach(el => {
                el.style.display = 'none !important';
                el.remove();
            });
        }
        
        removeAllBackToTop();
        document.addEventListener('DOMContentLoaded', removeAllBackToTop);
        setTimeout(removeAllBackToTop, 100);
        setTimeout(removeAllBackToTop, 300);
        setTimeout(removeAllBackToTop, 500);
        setTimeout(removeAllBackToTop, 1000);
        setInterval(removeAllBackToTop, 2000);
    </script>
</body>
</html>
